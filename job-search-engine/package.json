{
  "name": "orpheus",
  "version": "0.1.0",
  "description": "AI-powered job search engine built on MCP with parallel agents and full observability",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/cli.js",
    "start:server": "node dist/server/index.js",
    "search": "tsx src/cli.ts search",
    "dashboard": "tsx src/cli.ts dashboard",
    "apply": "tsx src/cli.ts apply",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "eventemitter3": "^5.0.1",
    "express": "^5.2.1",
    "ink": "^5.1.0",
    "nanoid": "^5.0.9",
    "ora": "^8.1.1",
    "p-limit": "^6.2.0",
    "p-queue": "^8.0.1",
    "react": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "job-search",
    "orchestration",
    "observability"
  ],
  "license": "MIT"
}
